\begin{frame}{Ключевые вехи истории}
    \begin{alertblock}{Хронология развития}
        \begin{itemize}
            \item \textbf{1931 г.} — Основание Индустриально-педагогического института в Орле.
            \item \textbf{1933 г.} — Реорганизация в Орловский педагогический институт и расширение физико-математического направления.
            \item \textbf{1941--1945 гг.} — Великая Отечественная война: героический вклад преподавателей и студентов (декан П.Д. Еремин, студент-герой Д. Сорин).
            \item \textbf{1996 г.} — Преобразование ОГПУ в классический государственный университет.
        \end{itemize}
    \end{alertblock}
\end{frame}

